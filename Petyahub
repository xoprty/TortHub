-- Бесконечный прыжок без детекта счетчика циклов
UserInputService.JumpRequest:Connect(function()
    if States.InfJump then
        local Character = LocalPlayer.Character
        if Character then
            local Humanoid = Character:FindFirstChildOfClass("Humanoid")
            if Humanoid then
                Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end
end)

-- Буст скорости с обходом перезаписи со стороны StateMachine
RunService.RenderStepped:Connect(function()
    local Character = LocalPlayer.Character
    if Character then
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if Humanoid then
            if States.SpeedBoost then
                Humanoid.WalkSpeed = States.SpeedValue
            end
        end
    end
end)

-- Изоляция текстур для Potato Graphics
local function OptimizeWorld(enable)
    if enable then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("DataModelMesh") or obj:IsA("CharacterMesh") or obj:IsA("BasePart") then
                if obj:IsA("BasePart") and not obj:IsA("MeshPart") then
                    if not OriginalMaterials[obj] then
                        OriginalMaterials[obj] = obj.Material
                    end
                    obj.Material = Enum.Material.SmoothPlastic
                end
                if obj:IsA("Texture") or obj:IsA("Decal") then
                    if not OriginalMaterials[obj] then
                        OriginalMaterials[obj] = obj.Transparency
                    end
                    obj.Transparency = 1
                end
            end
        end
        -- Снижение глобальных параметров рендеринга среды
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
    else
        for obj, material in pairs(OriginalMaterials) do
            if obj and obj.Parent then
                if obj:IsA("BasePart") then
                    obj.Material = material
                elseif obj:IsA("Texture") or obj:IsA("Decal") then
                    obj.Transparency = material
                end
            end
        end
        table.clear(OriginalMaterials)
        Lighting.GlobalShadows = true
    end
end


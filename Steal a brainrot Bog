-- 1. Кнопка TpSteal
local function findCollectZone()
    -- Ищем зеленую зону сбора игрока (обычно называется по имени игрока или имеет цвет)
    -- Скрипт сканирует Workspace на наличие платформ вашей базы
    local zones = workspace:FindFirstChild("Zones") or workspace:FindFirstChild("Tycoons") or workspace
    for _, zone in pairs(zones:GetDescendants()) do
        if zone:IsA("BasePart") and (zone.Name:lower():find("collect") or zone.Name:lower():find(LocalPlayer.Name:lower())) then
            if zone.Color.G > zone.Color.R and zone.Color.G > zone.Color.B then -- Проверка на то, что она преимущественно зеленая
                return zone
            end
        end
    end
    -- Запасной вариант, если структура режима специфическая (ищет просто по имени)
    return workspace:FindFirstChild(LocalPlayer.Name .. " Base") or workspace:FindFirstChild(LocalPlayer.Name .. "'s Zone")
end

TpStealBtn.MouseButton1Click:Connect(function()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    -- Проверяем, держит ли игрок вещь (Brainrot) в руках (внутри персонажа)
    local tool = character:FindFirstChildOfClass("Tool")
    
    if tool then
        local targetZone = findCollectZone()
        if targetZone then
            local targetPos = targetZone.Position + Vector3.new(0, 3, 0)
            
            -- Обход Античита: Плавный быстрый перелет (Tween) вместо резкого телепорта
            -- Резкий телепорт часто триггерит античит, а плавный за 0.2 сек сервер воспринимает как лаг
            local hrp = character.HumanoidRootPart
            local distance = (hrp.Position - targetPos).Magnitude
            local duration = math.clamp(distance / 150, 0.1, 0.3) -- динамическое время
            
            local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(targetPos)})
            
            -- Отключаем на долю секунды падение, чтобы не сбивать анимацию левитации
            local oldVelocity = hrp.AssemblyLinearVelocity
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            
            tween:Play()
        else
            -- Если авто-поиск не нашел зону, телепортируем на дефолтный спавн зоны (если он есть)
            print("База/Зона сбора не найдена. Попробуй встать ближе к ней один раз.")
        end
    else
        -- Мигание красным, если предмет не в руках
        local origColor = TpStealBtn.BackgroundColor3
        TpStealBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        task.wait(0.5)
        TpStealBtn.BackgroundColor3 = origColor
    end
end)

-- 2. Кнопка JumpB (Безопасный Бафф Прыжка)
local jumpBoostActive = false
local jumpConnection

JumpBBtn.MouseButton1Click:Connect(function()
    jumpBoostActive = not jumpBoostActive
    
    if jumpBoostActive then
        JumpBBtn.Text = "Jump Boost: ON"
        JumpBBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        
        -- Обход Античита: мы НЕ меняем JumpPower в Humanoid (античиты это проверяют каждую секунду).
        -- Вместо этого мы ловим момент прыжка и добавляем импульс (Velocity) телу вручную.
        local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local humanoid = character:WaitForChild("Humanoid")
        
        jumpConnection = humanoid.Jumping:Connect(function(isActive)
            if isActive and jumpBoostActive then
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    -- Добавляем деликатный толчок вверх (значение 35 можно изменить, если нужно выше/ниже)
                    task.wait(0.02) -- Микро-задержка для синхронизации с физикой роблокса
                    hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 65, hrp.AssemblyLinearVelocity.Z)
                end
            end
        end)
    else
        JumpBBtn.Text = "Jump Boost: OFF"
        JumpBBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 85)
        if jumpConnection then
            jumpConnection:Disconnect()
        end
    end
end)

-- Авто-переподключение прыжка при респавне
LocalPlayer.CharacterAdded:Connect(function(newCharacter)
    if jumpBoostActive then
        task.wait(1)
        local humanoid = newCharacter:WaitForChild("Humanoid")
        if jumpConnection then jumpConnection:Disconnect() end
        jumpConnection = humanoid.Jumping:Connect(function(isActive)
            if isActive and jumpBoostActive then
                local hrp = newCharacter:FindFirstChild("HumanoidRootPart")
                if hrp then
                    task.wait(0.02)
                    hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 65, hrp.AssemblyLinearVelocity.Z)
                end
            end
        end)
    end
end)

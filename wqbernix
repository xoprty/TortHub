local function setupGUI()
    -- Ожидаем полной загрузки игрока
    repeat wait() until LocalPlayer and LocalPlayer:IsA("Player") and LocalPlayer:FindFirstChild("PlayerGui")
    local playerGui = LocalPlayer.PlayerGui
    
    -- Удаляем старый GUI если есть
    local oldGui = playerGui:FindFirstChild("PetyaHub_v3")
    if oldGui then oldGui:Destroy() end
    
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "PetyaHub_v3"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = playerGui
    
    -- Проверка успешности
    if not ScreenGui.Parent then
        -- Fallback через CoreGui (с защитой)
        pcall(function()
            local coreGui = game:GetService("CoreGui")
            if coreGui then
                ScreenGui.Parent = coreGui
            end
        end)
    end
    
    return ScreenGui
end


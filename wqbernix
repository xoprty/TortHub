    local fpsLabel = Instance.new("TextLabel")
    fpsLabel.Size = UDim2.new(1, 0, 0.5, 0)
    fpsLabel.Position = UDim2.new(0, 0, 0, 0)
    fpsLabel.BackgroundTransparency = 1
    fpsLabel.Text = "FPS: 0"
    fpsLabel.TextColor3 = Color3.fromRGB(0, 255, 127)
    fpsLabel.Font = Enum.Font.Arcade
    fpsLabel.TextSize = 14
    fpsLabel.Parent = hudFrame
    
    local pingLabel = Instance.new("TextLabel")
    pingLabel.Size = UDim2.new(1, 0, 0.5, 0)
    pingLabel.Position = UDim2.new(0, 0, 0.5, 0)
    pingLabel.BackgroundTransparency = 1
    pingLabel.Text = "Ping: 0ms"
    pingLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    pingLabel.Font = Enum.Font.Arcade
    pingLabel.TextSize = 14
    pingLabel.Parent = hudFrame
    
    local frameCount = 0
    local lastTime = tick()
    
    RunService.RenderStepped:Connect(function()
        frameCount = frameCount + 1
        local now = tick()
        if now - lastTime >= 1 then
            local fps = math.floor(frameCount / (now - lastTime))
            fpsLabel.Text = "FPS: " .. fps
            frameCount = 0
            lastTime = now
        end
    end)
    
    -- Пинг из Stats
    task.spawn(function()
        while true do
            task.wait(2)
            local ping = Stats:FindFirstChild("Network") and Stats.Network:FindFirstChild("Ping") and Stats.Network.Ping.Value or 0
            pingLabel.Text = "Ping: " .. math.floor(ping) .. "ms"
        end
    end)
end


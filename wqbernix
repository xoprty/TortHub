local function createHUD()
    local hudFrame = Instance.new("Frame")
    hudFrame.Size = UDim2.new(0, 150, 0, 40)
    hudFrame.Position = UDim2.new(1, -160, 0, 10)
    hudFrame.BackgroundTransparency = 1

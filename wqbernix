local function findTimerText(obj)
    local function recursiveSearch(instance, depth)
        if depth and depth > 20 then return nil end
        if instance:IsA("TextLabel") or instance:IsA("TextMesh") or instance:IsA("TextBox") or instance:IsA("TextButton") then
            local text = instance.Text
            if text and (text:match("%d+%s*[sm]") or text:match("%d+:%d+") or text:match("%d+%s*с") or text:match("%d+%s*сек")) then
                return text:gsub("\n", " "):gsub("%s+", " ")
            end
        end
        for _, child in ipairs(instance:GetChildren()) do
            local res = recursiveSearch(child, (depth or 0) + 1)
            if res then return res end
        end
        return nil
    end
    return recursiveSearch(obj, 0)
end

local function CreateESP(object, text, color, stateKey, isPlayer)
    if ESP_Storage[object] then return end
    
    local Box = Instance.new("Highlight")
    Box.Adornee = object
    Box.FillColor = color
    Box.FillTransparency = 0.6
    Box.OutlineColor = Color3.fromRGB(255, 255, 255)
    Box.OutlineTransparency = 0.2
    Box.Parent = ScreenGui
    
    local Billboard = Instance.new("BillboardGui")
    Billboard.Adornee = isPlayer and object:FindFirstChild("HumanoidRootPart") or object
    Billboard.Size = UDim2.new(0, 200, 0, 50)
    Billboard.AlwaysOnTop = true
    Billboard.StudsOffset = Vector3.new(0, 3, 0)
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text or "0s"
    Label.TextColor3 = color
    Label.Font = Enum.Font.Arcade
    Label.TextSize = 14
    Label.Parent = Billboard
    Billboard.Parent = ScreenGui
    
    ESP_Storage[object] = {Box, Billboard, Label}
    
    task.spawn(function()
        while object and object.Parent and States[stateKey] do 
            if stateKey == "EspLock" then
                local timerText = findTimerText(object)
                if timerText then
                    Label.Text = timerText
                end
            end
            task.wait(0.2) 
        end
        Box:Destroy()
        Billboard:Destroy()
        ESP_Storage[object] = nil
    end)
end


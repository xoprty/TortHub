-- ========== ИСПОЛНИТЕЛЬНЫЕ КОМАНДЫ (исправленные) ==========
local function TriggerAutoWeb()
    local Character = LocalPlayer.Character
    if not Character then return end
    
    local Tool = LocalPlayer.Backpack:FindFirstChild("Web Slinger") or LocalPlayer.Backpack:FindFirstChild("WebSlinger") or Character:FindFirstChild("Web Slinger") or Character:FindFirstChild("WebSlinger")
    if not Tool then return end
    
    local TargetChar, Distance = GetClosestPlayerToMe()
    if not TargetChar then return end
    
    Tool.Parent = Character
    task.wait(0.1)
    
    local TargetRoot = TargetChar:FindFirstChild("HumanoidRootPart")
    if TargetRoot then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, TargetRoot.Position)
    end
    
    Tool:Activate()
    task.wait(0.05)
    -- Не деактивируем, чтобы сохранить эффект
    
    local Remote = Tool:FindFirstChildOfClass("RemoteEvent") or Tool:FindFirstChildOfClass("RemoteFunction")
    if Remote then
        local targetPlayer = Players:GetPlayerFromCharacter(TargetChar)
        pcall(function()
            if Remote:IsA("RemoteEvent") then
                Remote:FireServer(TargetChar)
                Remote:FireServer(TargetRoot)
                Remote:FireServer(TargetRoot.Position)
                if targetPlayer then Remote:FireServer(targetPlayer) end
            else
                Remote:InvokeServer(TargetChar)
                Remote:InvokeServer(TargetRoot)
                Remote:InvokeServer(TargetRoot.Position)
                if targetPlayer then Remote:InvokeServer(targetPlayer) end
            end
        end)
    end
end

local function TriggerBuyTrap()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local allRemotes = {}
    
    local function collect(obj)
        for _, child in ipairs(obj:GetDescendants()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                table.insert(allRemotes, child)
            end
        end
    end
    collect(ReplicatedStorage)
    collect(Workspace)
    collect(LocalPlayer.PlayerGui)
    collect(game:GetService("StarterGui"))
    
    local argsToTry = {
        {"Trap"}, {"trap"}, {"BuyTrap"}, {"buy trap"},
        {"Purchase", "Trap"}, {"Buy", "Trap"}, {"Shop", "Trap"},
        {"trap", 1}, {"Trap", 1}, {"BuyTrap", 1},
        {1, "Trap"}, {"Buy", "trap", 1}, {"Purchase", "trap", 1},
        {"PurchaseItem", "Trap"}, {"BuyItem", "Trap"},
        {"BuyTrap", "Trap"}, {"Buy", "Trap", "Trap"}
    }
    
    for _, remote in ipairs(allRemotes) do
        local name = remote.Name:lower()
        if name:find("shop") or name:find("store") or name:find("purchase") or name:find("buy") or name:find("trap") or name:find("item") or name:find("market") then
            for _, args in ipairs(argsToTry) do
                pcall(function()
                    if remote:IsA("RemoteEvent") then
                        remote:FireServer(unpack(args))
                    else
                        remote:InvokeServer(unpack(args))
                    end
                end)
            end
        end
    end
end


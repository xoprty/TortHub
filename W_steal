    end
end)

-- 2. JUMPBOOST
local jumpBoostEnabled = false
CreateButton("JUMPBOOST: OFF", MainPage, function(btn)
    jumpBoostEnabled = not jumpBoostEnabled
    btn.Text = "JUMPBOOST: " .. (jumpBoostEnabled and "ON" or "OFF")
    
    if LocalPlayer.Character then

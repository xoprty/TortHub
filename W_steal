end)

-- 3. TPBASE
CreateButton("TPBASE", MainPage, function()
    local baseFolder = Workspace:FindFirstChild("Bases") or Workspace:FindFirstChild("Tycoons") or Workspace
    local playerBase = nil
    
    -- Поиск базы по имени игрока или ID
    for _, base in pairs(baseFolder:GetChildren()) do
        if string.find(string.lower(base.name), string.lower(LocalPlayer.Name)) or (base:FindFirstChild("Owner") and base.Owner.Value == LocalPlayer) then
            playerBase = base
            break
        end
    end
    
    if playerBase then
        local spawnPart = playerBase:FindFirstChild("Spawn") or playerBase:FindFirstChild("MainPart") or playerBase:FindFirstChildOfClass("Part")
        if spawnPart and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = spawnPart.CFrame + Vector3.new(0, 3, 0)
        end
    end
end)

-- 4. ESP PLAYERS
local espPlayersEnabled = false
local playerFolderESP = {}

local function applyPlayerESP(player)
    if player == LocalPlayer then return end
    local function addBox(char)
        if not espPlayersEnabled then return end
        local rpart = char:WaitForChild("HumanoidRootPart", 5)
        if rpart and not rpart:FindFirstChild("Morn_ESP") then
            local box = Instance.new("BoxHandleAdornment")
            box.Name = "Morn_ESP"
            box.Size = Vector3.new(4, 6, 4)
            box.Color3 = Color3.fromRGB(0, 255, 150)
            box.AlwaysOnTop = true
            box.ZIndex = 5
            box.Adornee = rpart
            box.Transparency = 0.5
            box.Parent = rpart
        end
    end
    if player.Character then addBox(player.Character) end
    player.CharacterAdded:Connect(addBox)
end

CreateButton("ESP PLAYERS: OFF", ESPPage, function(btn)
    espPlayersEnabled = not espPlayersEnabled
    btn.Text = "ESP PLAYERS: " .. (espPlayersEnabled and "ON" or "OFF")
    
    if espPlayersEnabled then
        for _, p in pairs(Players:GetPlayers()) do applyPlayerESP(p) end
    else
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local e = p.Character.HumanoidRootPart:FindFirstChild("Morn_ESP")
                if e then e:Destroy() end
            end
        end
    end
end)

-- 5. ESP LOCK (Таймеры ворот/баз)
local espLockEnabled = false
local lockLabels = {}

RunService.RenderStepped:Connect(function()
    if not espLockEnabled then return end
    local bases = Workspace:FindFirstChild("Bases") or Workspace:FindFirstChild("Tycoons")
    if bases then
        for _, base in pairs(bases:GetChildren()) do
            local gate = base:FindFirstChild("Gate") or base:FindFirstChild("Door")
            local timerText = base:FindFirstChild("Timer") or base:FindFirstChild("Time") or (gate and gate:FindFirstChild("TextLabel"))
            
            if gate and not gate:FindFirstChild("Morn_LockESP") then
                local bgui = Instance.new("BillboardGui")
                bgui.Name = "Morn_LockESP"
                bgui.AlwaysOnTop = true
                bgui.Size = UDim2.new(0, 100, 0, 30)
                
                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, 0, 1, 0)
                lbl.BackgroundTransparency = 1
                lbl.TextColor3 = Color3.fromRGB(255, 50, 50)
                lbl.Font = Enum.Font.Code
                lbl.TextSize = 14
                lbl.Parent = bgui
                bgui.Parent = gate
                table.insert(lockLabels, bgui)
            end
            
            if gate and gate:FindFirstChild("Morn_LockESP") then
                local currentText = "Locked"
                if timerText then
                    if timerText:IsA("TextLabel") then currentText = timerText.Text
                    elseif timerText:IsA("StringValue") or timerText:IsA("IntValue") then currentText = tostring(timerText.Value) end
                end
                gate.Morn_LockESP.TextLabel.Text = "Time: " .. currentText
            end
        end
    end
end)

CreateButton("ESP LOCK: OFF", ESPPage, function(btn)
    espLockEnabled = not espLockEnabled
    btn.Text = "ESP LOCK: " .. (espLockEnabled and "ON" or "OFF")
    if not espLockEnabled then
        for _, v in pairs(lockLabels) do if v then v:Destroy() end end
        lockLabels = {}
    end
end)

-- 6. ESP BRAINROT
local espBrainrotEnabled = false
local brainrotLabels = {}

RunService.RenderStepped:Connect(function()
    if not espBrainrotEnabled then return end
    local bases = Workspace:FindFirstChild("Bases") or Workspace:FindFirstChild("Tycoons")
    if bases then
        for _, base in pairs(bases:GetChildren()) do
            local rotFolder = base:FindFirstChild("Brainrots") or base:FindFirstChild("DroppedItems") or base
            for _, rot in pairs(rotFolder:GetChildren()) do
                if rot:IsA("Model") or rot:IsA("Part") then
                    -- Фильтр объектов по ключевым признакам режима
                    if string.find(string.lower(rot.Name), "rot") or string.find(string.lower(rot.Name), "brain") or rot:FindFirstChild("Value") then
                        if not rot:FindFirstChild("Morn_RotESP") then
                            local mainPart = rot:IsA("Model") and (rot.PrimaryPart or rot:FindFirstChildOfClass("Part")) or rot
                            if mainPart then
                                local bgui = Instance.new("BillboardGui")
                                bgui.Name = "Morn_RotESP"
                                bgui.AlwaysOnTop = true
                                bgui.Size = UDim2.new(0, 120, 0, 30)
                                
                                local lbl = Instance.new("TextLabel")
                                lbl.Size = UDim2.new(1, 0, 1, 0)
                                lbl.BackgroundTransparency = 1
                                lbl.TextColor3 = Color3.fromRGB(200, 255, 0)
                                lbl.Font = Enum.Font.Code
                                lbl.TextSize = 12
                                lbl.Parent = bgui
                                bgui.Parent = mainPart
                                table.insert(brainrotLabels, bgui)
                            end
                        end
                        
                        if rot:FindFirstChild("Morn_RotESP") then
                            local val = rot:FindFirstChild("Value") or rot:FindFirstChild("Income")
                            local cashStr = val and tostring(val.Value) or "?"
                            local mainPart = rot:IsA("Model") and (rot.PrimaryPart or rot:FindFirstChildOfClass("Part")) or rot
                            if mainPart and mainPart:FindFirstChild("Morn_RotESP") then
                                mainPart.Morn_RotESP.TextLabel.Text = rot.Name .. " [$" .. cashStr .. "/s]"
                            end
                        end
                    end
                end
            end
        end
    end
end)

CreateButton("ESP BRAINROT: OFF", ESPPage, function(btn)
    espBrainrotEnabled = not espBrainrotEnabled
    btn.Text = "ESP BRAINROT: " .. (espBrainrotEnabled and "ON" or "OFF")
    if not espBrainrotEnabled then
        for _, v in pairs(brainrotLabels) do if v then v:Destroy() end end
        brainrotLabels = {}
    end
end)

-- 7. OPTIMIZATION
CreateButton("OPTIMIZATION", OptPage, function()
    Lighting.GlobalShadows = false
    for _, v in pairs(Lighting:GetEffects()) do
        v:Destroy()
    end
    
    -- Итерация по Workspace для удаления эффектов частиц брейкротов
    for _, desc in pairs(Workspace:GetDescendants()) do
        if desc:IsA("ParticleEmitter") or desc:IsA("Trail") or desc:IsA("Beam") or desc:IsA("Smoke") or desc:IsA("Sparkles") then
            desc:Destroy()
        end
    end
end)


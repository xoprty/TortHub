-- 3. TPBASE (На точку сбора / Collect Zone)
CreateButton("TP TO COLLECT", MainPage, function()
    local bases = Workspace:FindFirstChild("Bases") or Workspace:FindFirstChild("Tycoons") or Workspace
    local targetZone = nil
    
    for _, base in pairs(bases:GetChildren()) do
        if string.find(string.lower(base.Name), string.lower(LocalPlayer.Name)) or (base:FindFirstChild("Owner") and base.Owner.Value == LocalPlayer) then
            targetZone = base:FindFirstChild("Collect Zone") or base:FindFirstChild("CollectZone") or base:FindFirstChild("Collector") or base:FindFirstChild("Drop") or base:FindFirstChild("Delivery")
            break
        end
    end
    
    if targetZone and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        LocalPlayer.Character.HumanoidRootPart.CFrame = targetZone.CFrame + Vector3.new(0, 3, 0)
    end
end)

-- 4. FLY SYSTEM (Без багов и ТП)
local flying = false
local flySpeed = 50
local bVel, bGyro

CreateButton("FLY: OFF", MainPage, function(btn)
    flying = not flying
    btn.Text = "FLY: " .. (flying and "ON" or "OFF")
    
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if flying and hrp then
        bVel = Instance.new("BodyVelocity")
        bVel.MaxForce = Vector3.new(4e4, 4e4, 4e4)
        bVel.Velocity = Vector3.new(0, 0, 0)
        bVel.Parent = hrp
        
        bGyro = Instance.new("BodyGyro")
        bGyro.MaxTorque = Vector3.new(4e4, 4e4, 4e4)
        bGyro.CFrame = hrp.CFrame
        bGyro.Parent = hrp
        
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid.PlatformStand = true end
    else
        if bVel then bVel:Destroy() end
        if bGyro then bGyro:Destroy() end
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid.PlatformStand = false end
    end
end)

RunService.RenderStepped:Connect(function()
    if flying and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        local moveDir = Vector3.new(0, 0, 0)
        
        -- Логика направления камеры эмулятора
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + Camera.CFrame.RightVector end
        
        -- Поддержка интерфейса тачпада для мобильных (Delta)
        if UserInputService.TouchEnabled and moveDir.Magnitude == 0 then
            local movePart = LocalPlayer.Character:FindFirstChild("Humanoid") and LocalPlayer.Character.Humanoid.MoveDirection
            if movePart and movePart.Magnitude > 0 then
                moveDir = movePart
            end
        end
        
        if bVel and bGyro then
            bVel.Velocity = moveDir.Unit * flySpeed
            if moveDir.Magnitude == 0 then bVel.Velocity = Vector3.new(0, 0, 0) end
            bGyro.CFrame = Camera.CFrame
        end
    end
end)

-- 5. ESP PLAYERS
local espPlayersEnabled = false
local function applyPlayerESP(player)
    if player == LocalPlayer then return end
    local function addBox(char)
        if not espPlayersEnabled then return end
        local rpart = char:WaitForChild("HumanoidRootPart", 5)
        if rpart and not rpart:FindFirstChild("Morn_ESP") then
            local box = Instance.new("BoxHandleAdornment")
            box.Name = "Morn_ESP"
            box.Size = Vector3.new(4, 6, 4)
            box.Color3 = Color3.fromRGB(0, 255, 150)
            box.AlwaysOnTop = true
            box.Adornee = rpart
            box.Transparency = 0.6
            box.Parent = rpart
        end
    end
    if player.Character then addBox(player.Character) end
    player.CharacterAdded:Connect(addBox)
end

CreateButton("ESP PLAYERS: OFF", ESPPage, function(btn)
    espPlayersEnabled = not espPlayersEnabled
    btn.Text = "ESP PLAYERS: " .. (espPlayersEnabled and "ON" or "OFF")
    if espPlayersEnabled then
        for _, p in pairs(Players:GetPlayers()) do applyPlayerESP(p) end
    else
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local e = p.Character.HumanoidRootPart:FindFirstChild("Morn_ESP")
                if e then e:Destroy() end
            end
        end
    end
end)

-- 6. ESP LOCK
local espLockEnabled = false
local lockLabels = {}

RunService.Heartbeat:Connect(function()
    if not espLockEnabled then return end
    local bases = Workspace:FindFirstChild("Bases") or Workspace:FindFirstChild("Tycoons")
    if bases then
        for _, base in pairs(bases:GetChildren()) do
            local gate = base:FindFirstChild("Gate") or base:FindFirstChild("Door")
            local timerText = base:FindFirstChild("Timer") or base:FindFirstChild("Time")
            if gate and not gate:FindFirstChild("Morn_LockESP") then
                local bgui = Instance.new("BillboardGui")
                bgui.Name = "Morn_LockESP"
                bgui.AlwaysOnTop = true
                bgui.Size = UDim2.new(0, 80, 0, 20)
                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, 0, 1, 0)
                lbl.BackgroundTransparency = 1
                lbl.TextColor3 = Color3.fromRGB(255, 50, 50)
                lbl.Font = Enum.Font.Code
                lbl.TextSize = 10
                lbl.Parent = bgui
                bgui.Parent = gate
                table.insert(lockLabels, bgui)
            end
            if gate and gate:FindFirstChild("Morn_LockESP") then
                local currentText = "0"
                if timerText then currentText = timerText:IsA("TextLabel") and timerText.Text or tostring(timerText.Value) end
                gate.Morn_LockESP.TextLabel.Text = "Lock: " .. currentText
            end
        end
    end
end)

CreateButton("ESP LOCK: OFF", ESPPage, function(btn)
    espLockEnabled = not espLockEnabled
    btn.Text = "ESP LOCK: " .. (espLockEnabled and "ON" or "OFF")
    if not espLockEnabled then
        for _, v in pairs(lockLabels) do if v then v:Destroy() end end
        lockLabels = {}
    end
end)

-- 7. ESP BRAINROT
local espBrainrotEnabled = false
local brainrotLabels = {}

RunService.Heartbeat:Connect(function()
    if not espBrainrotEnabled then return end
    local bases = Workspace:FindFirstChild("Bases") or Workspace:FindFirstChild("Tycoons")
    if bases then
        for _, base in pairs(bases:GetChildren()) do
            local rotFolder = base:FindFirstChild("Brainrots") or base:FindFirstChild("DroppedItems") or base
            for _, rot in pairs(rotFolder:GetChildren()) do
                if rot:IsA("Model") or rot:IsA("Part") then
                    if string.find(string.lower(rot.Name), "rot") or string.find(string.lower(rot.Name), "brain") then
                        local mainPart = rot:IsA("Model") and (rot.PrimaryPart or rot:FindFirstChildOfClass("Part")) or rot
                        if mainPart and not mainPart:FindFirstChild("Morn_RotESP") then
                            local bgui = Instance.new("BillboardGui")
                            bgui.Name = "Morn_RotESP"
                            bgui.AlwaysOnTop = true
                            bgui.Size = UDim2.new(0, 100, 0, 20)
                            local lbl = Instance.new("TextLabel")
                            lbl.Size = UDim2.new(1, 0, 1, 0)
                            lbl.BackgroundTransparency = 1
                            lbl.TextColor3 = Color3.fromRGB(200, 255, 0)
                            lbl.Font = Enum.Font.Code
                            lbl.TextSize = 9
                            lbl.Parent = bgui
                            bgui.Parent = mainPart
                            table.insert(brainrotLabels, bgui)
                        end
                        if mainPart and mainPart:FindFirstChild("Morn_RotESP") then
                            local val = rot:FindFirstChild("Value") or rot:FindFirstChild("Income")
                            mainPart.Morn_RotESP.TextLabel.Text = rot.Name .. " [$" .. (val and tostring(val.Value) or "10") .. "/s]"
                        end
                    end
                end
            end
        end
    end
end)

CreateButton("ESP BRAINROT: OFF", ESPPage, function(btn)
    espBrainrotEnabled = not espBrainrotEnabled
    btn.Text = "ESP BRAINROT: " .. (espBrainrotEnabled and "ON" or "OFF")
    if not espBrainrotEnabled then
        for _, v in pairs(brainrotLabels) do if v then v:Destroy() end end
        brainrotLabels = {}
    end
end)


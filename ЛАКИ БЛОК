-- ФУНКЦИИ
-- -------------------------------------------------------------

-- Получить персонажа и гуманоида
local function getChar()
    local char = player.Character
    if not char then return nil, nil end
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return nil, nil end
    return char, hum
end

-- Обновление скорости полета
local function updateFlySpeed()
    local num = tonumber(speedBox.Text)
    if num and num >= 15 and num <= 500 then
        flySpeed = num
    else
        speedBox.Text = tostring(flySpeed)
    end
end

speedBox.FocusLost:Connect(function()
    updateFlySpeed()
end)

-- INFJUMP
infJumpButton.MouseButton1Click:Connect(function()
    infJumpActive = not infJumpActive
    local _, hum = getChar()
    if infJumpActive then
        if hum then hum.JumpPower = 100 end
        infJumpButton.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
    else
        if hum then hum.JumpPower = 50 end
        infJumpButton.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    end
end)

-- FLY
local function stopFly()
    if flyBodyVelocity then flyBodyVelocity:Destroy() flyBodyVelocity = nil end
    if flyBodyGyro then flyBodyGyro:Destroy() flyBodyGyro = nil end
    local _, hum = getChar()
    if hum then
        hum.PlatformStand = false
        hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
    end
    for _, conn in pairs(flyConnections) do
        conn:Disconnect()
    end
    flyConnections = {}
    moveVector = Vector3.new(0, 0, 0)
end

local function startFly()
    local char, hum = getChar()
    if not char or not hum then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    hum.PlatformStand = true
    hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)

    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
    flyBodyVelocity.Parent = root

    flyBodyGyro = Instance.new("BodyGyro")
    flyBodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    flyBodyGyro.Parent = root

    local function updateFly()
        if not flyBodyVelocity then return end
        local cam = workspace.CurrentCamera
        local forward = cam.CFrame.LookVector
        local right = cam.CFrame.RightVector
        local up = cam.CFrame.UpVector
        local vel = Vector3.new(0, 0, 0)
        if moveVector.X ~= 0 then vel = vel + right * moveVector.X * flySpeed end
        if moveVector.Z ~= 0 then vel = vel + forward * (-moveVector.Z) * flySpeed end
        if moveVector.Y ~= 0 then vel = vel + up * moveVector.Y * flySpeed end
        flyBodyVelocity.Velocity = vel
    end

    local function onInputBegan(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.W then moveVector = moveVector + Vector3.new(0,0,-1) updateFly() end
        if input.KeyCode == Enum.KeyCode.S then moveVector = moveVector + Vector3.new(0,0,1) updateFly() end
        if input.KeyCode == Enum.KeyCode.A then moveVector = moveVector + Vector3.new(-1,0,0) updateFly() end
        if input.KeyCode == Enum.KeyCode.D then moveVector = moveVector + Vector3.new(1,0,0) updateFly() end
        if input.KeyCode == Enum.KeyCode.Space then moveVector = moveVector + Vector3.new(0,1,0) updateFly() end
        if input.KeyCode == Enum.KeyCode.LeftShift then moveVector = moveVector + Vector3.new(0,-1,0) updateFly() end
    end

    local function onInputEnded(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.W then moveVector = moveVector - Vector3.new(0,0,-1) updateFly() end
        if input.KeyCode == Enum.KeyCode.S then moveVector = moveVector - Vector3.new(0,0,1) updateFly() end
        if input.KeyCode == Enum.KeyCode.A then moveVector = moveVector - Vector3.new(-1,0,0) updateFly() end
        if input.KeyCode == Enum.KeyCode.D then moveVector = moveVector - Vector3.new(1,0,0) updateFly() end
        if input.KeyCode == Enum.KeyCode.Space then moveVector = moveVector - Vector3.new(0,1,0) updateFly() end
        if input.KeyCode == Enum.KeyCode.LeftShift then moveVector = moveVector - Vector3.new(0,-1,0) updateFly() end
    end

    flyConnections["inputBegan"] = userInputService.InputBegan:Connect(onInputBegan)
    flyConnections["inputEnded"] = userInputService.InputEnded:Connect(onInputEnded)
end

flyButton.MouseButton1Click:Connect(function()
    flyActive = not flyActive
    if flyActive then
        flyButton.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        startFly()
    else
        flyButton.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        stopFly()
    end
end)


local TabVisuals = Window:MakeTab({Name = "Мир и ESP", Icon = "rbxassetid://4483345998", PremiumOnly = false})

-- ESP PLAYERS (Синий цвет, ники)
local espObjects = {}
TabVisuals:AddToggle({
    Name = "ESP PLAYERS (Синяя подсветка)",
    Default = false,
    Callback = function(Value)
        if Value then
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= Player and p.Character then
                    -- Создание Highlight (подсветки)
                    local hl = Instance.new("Highlight")
                    hl.Parent = p.Character
                    hl.FillColor = Color3.fromRGB(0, 120, 255) -- Синий цвет
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                    hl.FillTransparency = 0.5
                    table.insert(espObjects, hl)
                    
                    -- Создание ника над головой (если встроенного нет)
                    local bbg = Instance.new("BillboardGui", p.Character)
                    bbg.Size = UDim2.new(0, 200, 0, 50)
                    bbg.AlwaysOnTop = true
                    bbg.StudsOffset = Vector3.new(0, 3, 0)
                    local lbl = Instance.new("TextLabel", bbg)
                    lbl.Size = UDim2.new(1, 0, 1, 0)
                    lbl.BackgroundTransparency = 1
                    lbl.Text = p.Name
                    lbl.TextColor3 = Color3.fromRGB(0, 160, 255)
                    lbl.Font = Enum.Font.SourceSansBold
                    lbl.TextSize = 18
                    table.insert(espObjects, bbg)
                end
            end
        else
            for _, obj in pairs(espObjects) do
                if obj then obj:Destroy() end
            end
            table.clear(espObjects)
        end
    end
})

-- OPEN THE FRIEND (Допуск друзей на базу)
TabVisuals:AddButton({
    Name = "OPEN THE FRIEND (Доступ друзьям)",
    Callback = function()
        -- Скрипт ищет дверь или барьер базы игрока и убирает коллизию для друзей
        -- Так как название баз зависит от игры, скрипт находит все барьеры "Friend" или "WhiteList"
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and (v.Name:lower():find("gate") or v.Name:lower():find("door") or v.Name:lower():find("border")) then
                -- Убираем хитбокс двери для всех, кроме владельца (могут заходить друзья)
                v.CanCollide = false
            end
        end
        OrionLib:MakeNotification({Name = "База открыта!", Content = "Ваши друзья теперь могут заходить на базу.", Image = "rbxassetid://4483345998", Duration = 5})
    end
})


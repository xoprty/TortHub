-- Функция автоматического поиска зоны сбора (Зеленой/Collect Zone)
local function getCollectZone()
    local paths = {workspace:FindFirstChild("Zones"), workspace:FindFirstChild("Tycoons"), workspace}
    for _, path in pairs(paths) do
        if path then
            for _, obj in pairs(path:GetDescendants()) do
                if obj:IsA("BasePart") and (obj.Name:lower():find("collect") or obj.Name:lower():find("multi") or obj.Name:lower():find(LocalPlayer.Name:lower())) then
                    -- Проверяем, преобладает ли зеленый цвет в палитре зоны
                    if obj.Color.G > obj.Color.R and obj.Color.G > obj.Color.B then
                        return obj
                    end
                end
            end
        end
    end
    return nil
end

-- Обновление ползунка / индикатора дистанции в реальном времени
RunService.Heartbeat:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local zone = getCollectZone()
        if zone then
            local dist = (LocalPlayer.Character.HumanoidRootPart.Position - zone.Position).Magnitude
            DistanceLabel.Text = "Distance to Base: " .. math.floor(dist) .. "m"
        else
            DistanceLabel.Text = "Distance: Zone Not Found"
        end
    end
end)

-- 1. ЛОГИКА КНОПКИ TPZONE (Безопасный перенос без выпадения предметов)
TpZoneBtn.MouseButton1Click:Connect(function()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then
        -- Визуальный эффект ошибки, если ничего не украдено
        TpZoneBtn.Text = "Hold Brainrot first!"
        task.wait(1)
        TpZoneBtn.Text = "TpZone"
        return
    end
    
    local zone = getCollectZone()
    if zone then
        local hrp = char.HumanoidRootPart
        local targetCFrame = CFrame.new(zone.Position + Vector3.new(0, 3, 0))
        
        -- Bypass: Плавное перемещение "микро-телепортами" каждый кадр.
        -- Это обходит проверки на скорость (Speed-Check) и моментальные координаты, сохраняя предмет в руках.
        local distance = (hrp.Position - targetCFrame.Position).Magnitude
        local speed = 160 -- Безопасная скорость для обхода
        local duration = distance / speed
        local startCFrame = hrp.CFrame
        local elapsed = 0
        
        local connection
        connection = RunService.Heartbeat:Connect(function(delta)
            elapsed = elapsed + delta
            local progress = math.min(elapsed / duration, 1)
            
            if char and char:FindFirstChild("HumanoidRootPart") then
                hrp.CFrame = startCFrame:Lerp(targetCFrame, progress)
                hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0) -- гасим скорость, чтобы не швыряло античитом
            end
            
            if progress >= 1 then
                connection:Disconnect()
            end
        end)
    end
end)

-- 2. ЛОГИКА КНОПКИ JUMPB (INFINITE JUMP)
local infJumpActive = false
local jumpFixConnection

JumpBBtn.MouseButton1Click:Connect(function()
    infJumpActive = not infJumpActive
    if infJumpActive then
        JumpBBtn.Text = "InfJump: ON"
        JumpBBtn.BackgroundColor3 = Color3.fromRGB(140, 80, 255)
        
        -- Ловим нажатие прыжка в воздухе напрямую через систему ввода игрока
        jumpFixConnection = UserInputService.JumpRequest:Connect(function()
            if infJumpActive and LocalPlayer.Character then
                local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
        end)
    else
        JumpBBtn.Text = "InfJump: OFF"
        JumpBBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
        if jumpFixConnection then
            jumpFixConnection:Disconnect()
        end
    end
end)

-- 3. ЛОГИКА КНОПКИ STEALRESET (Глитч сохранения предмета через ресет)
StealResetBtn.MouseButton1Click:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        -- Заставляем игру думать, что брэинрот привязан к структуре игрока перманентно
        tool.Parent = LocalPlayer.Backpack
        task.wait(0.05)
        
        -- Ломаем здоровье для респавна
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.Health = 0
        end
        
        -- Сразу при перерождении автоматически экипируем его обратно
        local spawnConnection
        spawnConnection = LocalPlayer.CharacterAdded:Connect(function(newChar)
            local backpack = LocalPlayer:WaitForChild("Backpack")
            local targetTool = backpack:WaitForChild(tool.Name, 5)
            if targetTool then
                task.wait(0.1)
                targetTool.Parent = newChar
            end
            spawnConnection:Disconnect()
        end)
    else
        StealResetBtn.Text = "No Item to Bug!"
        task.wait(1)
        StealResetBtn.Text = "StealReset"
    end
end)

-- ОПТИМИЗАЦИЯ СЕТИ (СТАБИЛЬНОЕ ПОВЫШЕНИЕ FPS)
--------------------------------------------------------------------------------

local function OptimizeWorld(enable)
    if enable then
        -- Жесткое отключение тяжелых эффектов постобработки
        for _, fx in ipairs(Lighting:GetChildren()) do
            if fx:IsA("PostEffect") or fx:IsA("DepthOfFieldEffect") or fx:IsA("BlurEffect") then
                fx.Enabled = false
            end
        end
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        Lighting.GlobalShadows = false
        
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") then
                if not OriginalMaterials[obj] then OriginalMaterials[obj] = {obj.Material, obj.Reflectance} end
                obj.Material = Enum.Material.SmoothPlastic
                obj.Reflectance = 0
            elseif obj:IsA("Decal") or obj:IsA("Texture") then
                if not OriginalMaterials[obj] then OriginalMaterials[obj] = obj.Texture end
                obj.Texture = "rbxassetid://0" -- Полная выгрузка без поломки структуры дерева
            end
        end
        if Workspace:FindFirstChildOfClass("Terrain") then
            Workspace:FindFirstChildOfClass("Terrain").WaterWaveSize = 0
            Workspace:FindFirstChildOfClass("Terrain").WaterWaveSpeed = 0
        end
    else
        -- Возврат исходных параметров
        for _, fx in ipairs(Lighting:GetChildren()) do
            if fx:IsA("PostEffect") or fx:IsA("DepthOfFieldEffect") or fx:IsA("BlurEffect") then
                fx.Enabled = true
            end
        end
        Lighting.GlobalShadows = true
        for obj, data in pairs(OriginalMaterials) do
            if obj and obj.Parent then
                if obj:IsA("BasePart") then
                    obj.Material = data[1]
                    obj.Reflectance = data[2]
                else
                    obj.Texture = data
                end
            end
        end
        table.clear(OriginalMaterials)
    end
end


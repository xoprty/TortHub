local function CreateESP(object, text, color, stateKey)
    if ESP_Storage[object] then return end
    
    local Box = Instance.new("Highlight")
    Box.Adornee = object
    Box.FillColor = color
    Box.FillTransparency = 0.6
    Box.OutlineColor = Color3.fromRGB(255, 255, 255)
    Box.OutlineTransparency = 0.2
    Box.Parent = ScreenGui
    
    local Billboard = Instance.new("BillboardGui")
    Billboard.Adornee = object
    Billboard.Size = UDim2.new(0, 200, 0, 50)
    Billboard.AlwaysOnTop = true
    Billboard.StudsOffset = Vector3.new(0, 3, 0)
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = color
    Label.Font = Enum.Font.Arcade
    Label.TextSize = 14
    Label.Parent = Billboard
    Billboard.Parent = ScreenGui
    
    ESP_Storage[object] = {Box, Billboard}
    
    task.spawn(function()
        while object and object.Parent and States[stateKey] do task.wait(0.5) end
        Box:Destroy()
        Billboard:Destroy()
        ESP_Storage[object] = nil
    end)
end

task.spawn(function()
    while true do
        task.wait(1)
        if States.EspPlayers then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    CreateESP(p.Character.HumanoidRootPart, p.Name, Color3.fromRGB(0, 255, 255), "EspPlayers")
                end
            end
        end
        if States.EspLock or States.EspBrainrot then
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if States.EspLock and (obj.Name:lower():find("base") or obj.Name:lower():find("lock")) and obj:IsA("BasePart") then
                    CreateESP(obj, "[BASE/LOCK]", Color3.fromRGB(255, 170, 0), "EspLock")
                end
                if States.EspBrainrot and obj.Name:lower():find("brainrot") and obj:IsA("BasePart") then
                    CreateESP(obj, "[TOP BRAINROT]", Color3.fromRGB(255, 0, 127), "EspBrainrot")
                end
            end
        end
    end
end)


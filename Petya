-- Безопасный обход античита прыжков через импульс физики
local LastJump = 0
UserInputService.JumpRequest:Connect(function()
    if States.InfJump and tick() - LastJump > 0.15 then
        local Character = LocalPlayer.Character
        local Root = Character and Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
        
        if Root and Humanoid then
            LastJump = tick()
            -- Вместо смены стейта — силовой толчок вверх, обходящий счетчик стейтов гуманоида
            Root.Velocity = Vector3.new(Root.Velocity.X, States.JumpBoost and States.JumpValue or 50, Root.Velocity.Z)
        end
    end
end)

-- Контур контроля SpeedBoost и стандартного JumpBoost
RunService.PostSimulation:Connect(function()
    local Character = LocalPlayer.Character
    if Character then
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if Humanoid then
            if States.SpeedBoost then
                Humanoid.WalkSpeed = States.SpeedValue
            end
            if States.JumpBoost and not States.InfJump then
                Humanoid.JumpPower = States.JumpValue
                Humanoid.UseJumpPower = true
            elseif not States.JumpBoost and not States.InfJump then
                Humanoid.JumpPower = 50
            end
        end
    end
end)

-- Контур AUTOWEB (Auto Aim для Web Slinger)
local function GetClosestPlayerToCursor()
    local Target = nil
    local MinDistance = math.huge
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local Root = player.Character.HumanoidRootPart
            local ScreenPos, OnScreen = Camera:WorldToScreenPoint(Root.Position)
            
            if OnScreen then
                local MousePos = UserInputService:GetMouseLocation()
                local Distance = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
                if Distance < MinDistance and Distance < 300 then -- Радиус захвата 300 пикселей
                    MinDistance = Distance
                    Target = Root
                end
            end
        end
    end
    return Target
end

-- Перехват активации Web Slinger
local AimConnection
RunService.RenderStepped:Connect(function()
    if States.AutoWeb then
        local Character = LocalPlayer.Character
        -- Проверка наличия Web Slinger в руках
        if Character and Character:FindFirstChild("Web Slinger") or Character:FindFirstChild("WebSlinger") then
            local Target = GetClosestPlayerToCursor()
            if Target and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                -- Направление камеры на цель дляDelta/инжектор совместимости
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Position)
            end
        end
    end
end)


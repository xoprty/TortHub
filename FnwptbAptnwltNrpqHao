-- АГРЕССИВНАЯ ОПТИМИЗАЦИЯ СЕТИ ДЛЯ ПОВЫШЕНИЯ FPS (POTATO MODE)
--------------------------------------------------------------------------------

local function OptimizeWorld(enable)
    if enable then
        -- Полная жесткая зачистка элементов рендеринга
        Lighting.GlobalShadows = false
        for _, fx in ipairs(Lighting:GetChildren()) do
            if fx:IsA("PostEffect") or fx:IsA("DepthOfFieldEffect") or fx:IsA("BlurEffect") or fx:IsA("SunRaysEffect") then
                fx.Enabled = false
            end
        end
        
        -- Выгрузка 3D текстур, эффектов и материалов
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") then
                if not OriginalMaterials[obj] then OriginalMaterials[obj] = {obj.Material, obj.Reflectance, obj.CastShadow} end
                obj.Material = Enum.Material.SmoothPlastic
                obj.Reflectance = 0
                obj.CastShadow = false
            elseif obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("Clothing") then
                if not OriginalMaterials[obj] then OriginalMaterials[obj] = obj.Texture or obj.TextureId end
                pcall(function() obj:Destroy() end) -- Полное удаление текстур из памяти для буста FPS
            elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Sparkles") then
                obj.Enabled = false
            end
        end
        
        -- Сброс настроек качества Delta среды через скрытые свойства, если доступны
        pcall(function()
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
            sethiddenproperty(Workspace.CurrentCamera, "AllowFrustumCulling", true)
        end)
    else
        -- Безопасное восстановление геометрии
        Lighting.GlobalShadows = true
        for _, fx in ipairs(Lighting:GetChildren()) do
            if fx:IsA("PostEffect") or fx:IsA("DepthOfFieldEffect") or fx:IsA("BlurEffect") then
                fx.Enabled = true
            end
        end
        for obj, data in pairs(OriginalMaterials) do
            if obj and obj.Parent and obj:IsA("BasePart") then
                obj.Material = data[1]
                obj.Reflectance = data[2]
                obj.CastShadow = data[3]
            end
        end
        table.clear(OriginalMaterials)
    end
end


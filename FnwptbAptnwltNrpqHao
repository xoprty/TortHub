-- Безопасный обход античита прыжков через импульс физики
local LastJump = 0
UserInputService.JumpRequest:Connect(function()
    if States.InfJump and tick() - LastJump > 0.15 then
        local Character = LocalPlayer.Character
        local Root = Character and Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
        
        if Root and Humanoid then
            LastJump = tick()
            Root.Velocity = Vector3.new(Root.Velocity.X, States.JumpBoost and States.JumpValue or 50, Root.Velocity.Z)
        end
    end
end)

-- Контур контроля SpeedBoost и стандартного JumpBoost
RunService.PostSimulation:Connect(function()
    local Character = LocalPlayer.Character
    if Character then
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if Humanoid then
            if States.SpeedBoost then
                Humanoid.WalkSpeed = States.SpeedValue
            end
            if States.JumpBoost and not States.InfJump then
                Humanoid.JumpPower = States.JumpValue
                Humanoid.UseJumpPower = true
            elseif not States.JumpBoost and not States.InfJump then
                Humanoid.JumpPower = 50
            end
        end
    end
end)

-- Контур AUTOWEB (Корректное доведение снаряда/луча без вращения камеры)
local function GetClosestPlayerToMouse()
    local Target = nil
    local MinDistance = math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local Root = player.Character.HumanoidRootPart
            local ScreenPos, OnScreen = Camera:WorldToScreenPoint(Root.Position)
            if OnScreen then
                local MousePos = UserInputService:GetMouseLocation()
                local Distance = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
                if Distance < MinDistance and Distance < 500 then -- Радиус доводки
                    MinDistance = Distance
                    Target = Root
                end
            end
        end
    end
    return Target
end

-- Перехват точки прицеливания (Silent Aim для Web Slinger)
local oldHook
oldHook = hookmetamethod(game, "__index", function(self, key)
    if States.AutoWeb and self == Mouse and (key == "Hit" or key == "Target") then
        local Character = LocalPlayer.Character
        if Character and (Character:FindFirstChild("Web Slinger") or Character:FindFirstChild("WebSlinger")) then
            local Target = GetClosestPlayerToMouse()
            if Target then
                return (key == "Hit" and Target.CFrame or Target)
            end
        end
    end
    return oldHook(self, key)
end)

-- Контур DESYNC (Автоматический клик и переключение Portal Gun)
task.spawn(function()
    while true do
        task.wait(0.1)
        if States.Desync then
            local Character = LocalPlayer.Character
            local Backpack = LocalPlayer:FindFirstChild("Backpack")
            if Character and Backpack then
                local PortalGun = Character:FindFirstChild("Portal Gun") or Character:FindFirstChild("PortalGun") or Backpack:FindFirstChild("Portal Gun") or Backpack:FindFirstChild("PortalGun")
                if PortalGun then
                    -- Экипировать
                    if PortalGun.Parent == Backpack then
                        PortalGun.Parent = Character
                    end
                    -- Генерация выстрела портала под себя для смещения хитбокса
                    pcall(function()
                        PortalGun:Activate()
                    end)
                    task.wait(0.05)
                    -- Быстрый сброс для сброса анимаций и позиционирования античита
                    if PortalGun.Parent == Character then
                        PortalGun.Parent = Backpack
                    end
                end
            end
        end
    end
end)


-- AUTOHEEL (восстановление здоровья)
local function toggleAutoHeel()
    states.AUTOHEEL = not states.AUTOHEEL
    if states.AUTOHEEL then
        local hum = getHumanoid()
        if hum then
            hum.Health = hum.MaxHealth
        end
        -- запускаем цикл восстановления
        while states.AUTOHEEL do
            wait(0.5)
            local hum = getHumanoid()
            if hum then
                hum.Health = hum.MaxHealth
            end
        end
    end
end

-- GODMOD
local function toggleGodMode()
    states.GODMOD = not states.GODMOD
    if states.GODMOD then
        local hum = getHumanoid()
        if hum then
            hum.Health = hum.MaxHealth
            hum:BreakJoints() -- не ломаем
            -- защита от урона
            hookfunction(hum, "TakeDamage", function(self, amount)
                return
            end)
        end
    else
        -- восстанавливаем функции
        -- не будем восстанавливать, просто выключим
    end
end

-- NOHUNGER (заморозка голода)
local function toggleNoHunger()
    states.NOHUNGER = not states.NOHUNGER
    if states.NOHUNGER then
        -- ищем голод в игроке (обычно это IntValue или NumberValue)
        local hunger = LocalPlayer:FindFirstChild("Hunger") or LocalPlayer:FindFirstChild("Food") or LocalPlayer:FindFirstChild("Stamina")
        if hunger then
            hunger.Changed:Connect(function()
                if states.NOHUNGER then
                    hunger.Value = hunger.Value -- замораживаем (или устанавливаем высокое)
                end
            end)
        end
    end
end

-- ESP (подсветка игроков и существ)
local espHighlights = {}
local function toggleESP()
    states.ESP = not states.ESP
    if states.ESP then
        -- создаем Highlight для каждого игрока и NPC
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                local char = plr.Character
                if char then
                    local highlight = Instance.new("Highlight")
                    highlight.Adornee = char
                    highlight.FillColor = Color3.fromRGB(0, 255, 0)
                    highlight.FillTransparency = 0.5
                    highlight.OutlineColor = Color3.fromRGB(0, 255, 0)
                    highlight.OutlineTransparency = 0.3
                    highlight.Parent = char
                    espHighlights[plr] = highlight
                end
            end
        end
        -- для существ (например, NPC)
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= LocalPlayer.Character then
                local highlight = Instance.new("Highlight")
                highlight.Adornee = obj
                highlight.FillColor = Color3.fromRGB(0, 255, 0)
                highlight.FillTransparency = 0.5
                highlight.OutlineColor = Color3.fromRGB(0, 255, 0)
                highlight.OutlineTransparency = 0.3
                highlight.Parent = obj
                espHighlights[obj] = highlight
            end
        end
    else
        for _, h in pairs(espHighlights) do
            h:Destroy()
        end
        espHighlights = {}
    end
end


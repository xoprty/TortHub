-- INFJUMP
local function toggleInfJump()
    states.INFJUMP = not states.INFJUMP
    if states.INFJUMP then
        -- делаем прыжок высоким и разрешаем повторный прыжок в воздухе
        local hum = getHumanoid()
        if hum then
            hum.JumpPower = 80
            hum.UseJumpPower = true
            -- отключаем ограничение на повторный прыжок
            hookfunction(hum, "CheckJump", function() return true end)  -- небезопасно, лучше через обертку
        end
    else
        local hum = getHumanoid()
        if hum then
            hum.JumpPower = 50
            hum.UseJumpPower = true
        end
    end
end

-- JUMPBOOST (увеличение JumpPower на время)
local function toggleJumpBoost()
    states.JUMPBOOST = not states.JUMPBOOST
    if states.JUMPBOOST then
        local hum = getHumanoid()
        if hum then
            hum.JumpPower = 120
        end
    else
        local hum = getHumanoid()
        if hum then
            hum.JumpPower = 50
        end
    end
end

-- TPFIRE (телепорт к огню/зоне сохранения)
local function tpFire()
    local char = getChar()
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    -- ищем объект с именем "Fire" или "SaveZone" (зависит от игры)
    local fire = nil
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:lower():find("fire") or obj.Name:lower():find("save")) then
            fire = obj
            break
        end
    end
    if fire then
        root.CFrame = fire.CFrame + Vector3.new(0, 3, 0)
    else
        -- если не нашли, просто телепорт в центр карты
        root.CFrame = CFrame.new(0, 20, 0)
    end
end

-- FLY
local flyBodyVelocity = nil
local flyEnabled = false
local flySpeed = 50
local function toggleFly()
    states.FLY = not states.FLY
    if states.FLY then
        local char = getChar()
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        if flyBodyVelocity then flyBodyVelocity:Destroy() end
        flyBodyVelocity = Instance.new("BodyVelocity")
        flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        flyBodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
        flyBodyVelocity.Parent = root
        flyEnabled = true
        -- управление клавишами
        local function onInput(input, processed)
            if processed then return end
            if not flyEnabled then return end
            local root = getChar() and getChar():FindFirstChild("HumanoidRootPart")
            if not root then return end
            local direction = Vector3.new(0, 0, 0)
            if input.KeyCode == Enum.KeyCode.W then direction = direction + root.CFrame.LookVector * flySpeed end
            if input.KeyCode == Enum.KeyCode.S then direction = direction - root.CFrame.LookVector * flySpeed end
            if input.KeyCode == Enum.KeyCode.A then direction = direction - root.CFrame.RightVector * flySpeed end
            if input.KeyCode == Enum.KeyCode.D then direction = direction + root.CFrame.RightVector * flySpeed end
            if input.KeyCode == Enum.KeyCode.Space then direction = direction + Vector3.new(0, flySpeed, 0) end
            if input.KeyCode == Enum.KeyCode.LeftShift then direction = direction + Vector3.new(0, -flySpeed, 0) end
            if direction.Magnitude > 0 then
                flyBodyVelocity.Velocity = direction
            else
                flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
            end
        end
        UserInputService.InputBegan:Connect(onInput)
        -- также привязываем к рендеру для непрерывности
        RunService.Heartbeat:Connect(function()
            if flyEnabled and flyBodyVelocity then
                local root = getChar() and getChar():FindFirstChild("HumanoidRootPart")
                if not root then return end
                -- небольшое демпфирование
            end
        end)
    else
        flyEnabled = false
        if flyBodyVelocity then
            flyBodyVelocity:Destroy()
            flyBodyVelocity = nil
        end
        -- отключаем управление
    end
end


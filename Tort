-- Функции
local function toggleInfJump()
    infJumpEnabled = not infJumpEnabled
    if infJumpEnabled then
        humanoid.JumpPower = 100
        humanoid:GetPropertyChangedSignal("Jump"):Connect(function()
            if humanoid.Jump and infJumpEnabled then
                -- сбрасываем счётчик падения, чтобы не убивало
                humanoid.Jump = true
            end
        end)
        -- Защита от убийства при падении
        humanoid.StateChanged:Connect(function(old, new)
            if infJumpEnabled and new == Enum.HumanoidStateType.Falling then
                humanoid.Jump = true
            end
        end)
    else
        humanoid.JumpPower = 50
    end
end

local function toggleSpeedBoost()
    speedBoostEnabled = not speedBoostEnabled
    if speedBoostEnabled then
        humanoid.WalkSpeed = 50
    else
        humanoid.WalkSpeed = 16
    end
end

local function toggleOptPhone()
    optPhoneEnabled = not optPhoneEnabled
    if optPhoneEnabled then
        -- картофельная графика
        Lighting.Brightness = 0.5
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 100
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") then
                v.Material = Enum.Material.Plastic
                v.Reflectance = 0
            end
        end
        -- буст производительности
        settings().RenderQuality = Enum.RenderQuality.Automatic
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    else
        -- возврат к норме (приблизительно)
        Lighting.Brightness = 1
        Lighting.GlobalShadows = true
        Lighting.FogEnd = 1000
        settings().RenderQuality = Enum.RenderQuality.Level01
    end
end

-- Кнопки в меню
local function createBtn(text, yPos, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.8, 0, 0, 30)
    btn.Position = UDim2.new(0.1, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.new(0.3, 0.05, 0.1)
    btn.Text = text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextScaled = true
    btn.Font = Enum.Font.Gotham
    btn.Parent = menuFrame
    btn.MouseButton1Click:Connect(callback)
    return btn
end

createBtn("INFJUMP", 40, toggleInfJump)
createBtn("SPEEDBOOST", 80, toggleSpeedBoost)
createBtn("OPTPHONE", 120, toggleOptPhone)

-- Открытие/закрытие по клику на круг
circleBtn.MouseButton1Click:Connect(function()
    menuOpen = not menuOpen
    menuFrame.Visible = menuOpen
end)

-- Обработка закрытия по клику вне меню (опционально)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if menuOpen then
            local mousePos = UserInputService:GetMouseLocation()
            local framePos = menuFrame.AbsolutePosition
            local frameSize = menuFrame.AbsoluteSize
            if not (mousePos.X >= framePos.X and mousePos.X <= framePos.X + frameSize.X and
                    mousePos.Y >= framePos.Y and mousePos.Y <= framePos.Y + frameSize.Y) then
                menuOpen = false
                menuFrame.Visible = false
            end
        end
    end
end)

-- Сброс при перезаходе
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = character:WaitForChild("Humanoid")
    if speedBoostEnabled then humanoid.WalkSpeed = 50 end
    if infJumpEnabled then humanoid.JumpPower = 100 end
end)

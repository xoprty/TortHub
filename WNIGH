            root.CFrame = obj.CFrame + Vector3.new(0, 2, 0)
            return
        end
    end
end

-- FREECAM
local freeCamConnection = nil
local function toggleFreeCam(state)
    states.FREECAM = state
    local camera = Workspace.CurrentCamera
    if state then
        camera.CameraType = Enum.CameraType.Scriptable
        local root = getRoot()
        if root then camera.CFrame = root.CFrame + Vector3.new(0, 10, 20) end
        if not freeCamConnection then
            freeCamConnection = RunService.Heartbeat:Connect(function()
                if not states.FREECAM then return end
            end)
        end
    else
        camera.CameraType = Enum.CameraType.Custom
        if freeCamConnection then
            freeCamConnection:Disconnect()
            freeCamConnection = nil
        end
    end
end

-- PRDAY
local function togglePRDay(state)
    states.PRDAY = state
    if state then
        Lighting.ClockTime = 12
    end
end


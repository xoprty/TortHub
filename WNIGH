-- ESP
local espHighlights = {}
local espConnection = nil
local function toggleESP(state)
    states.ESP = state
    if state then
        for _, h in pairs(espHighlights) do h:Destroy() end
        espHighlights = {}
        local function updateESP()
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer then
                    local char = plr.Character
                    if char then
                        if not espHighlights[plr] then
                            local hl = Instance.new("Highlight")
                            hl.Adornee = char
                            hl.FillColor = Color3.fromRGB(0, 255, 0)
                            hl.FillTransparency = 0.5
                            hl.OutlineColor = Color3.fromRGB(0, 255, 0)
                            hl.OutlineTransparency = 0.3
                            hl.Parent = char
                            espHighlights[plr] = hl
                        end
                    else
                        if espHighlights[plr] then
                            espHighlights[plr]:Destroy()
                            espHighlights[plr] = nil
                        end
                    end
                end
            end
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= LocalPlayer.Character and not Players:GetPlayerFromCharacter(obj) then
                    if not espHighlights[obj] then
                        local hl = Instance.new("Highlight")
                        hl.Adornee = obj
                        hl.FillColor = Color3.fromRGB(0, 255, 0)
                        hl.FillTransparency = 0.5
                        hl.OutlineColor = Color3.fromRGB(0, 255, 0)
                        hl.OutlineTransparency = 0.3
                        hl.Parent = obj
                        espHighlights[obj] = hl
                    end
                end
            end
        end
        updateESP()
        if not espConnection then
            espConnection = RunService.Heartbeat:Connect(updateESP)
        end
    else
        if espConnection then espConnection:Disconnect() espConnection = nil end
        for _, h in pairs(espHighlights) do h:Destroy() end
        espHighlights = {}
    end
end


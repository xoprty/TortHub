-- ESP (подсветка игроков и существ)
local espHighlights = {}
local espConnection = nil
local function toggleESP(state)
    states.ESP = state
    if state then
        -- очищаем старые
        for _, h in pairs(espHighlights) do h:Destroy() end
        espHighlights = {}
        -- функция обновления ESP
        local function updateESP()
            -- игроки
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer then
                    local char = plr.Character
                    if char then
                        if not espHighlights[plr] then
                            local highlight = Instance.new("Highlight")
                            highlight.Adornee = char
                            highlight.FillColor = Color3.fromRGB(0, 255, 0)
                            highlight.FillTransparency = 0.5
                            highlight.OutlineColor = Color3.fromRGB(0, 255, 0)
                            highlight.OutlineTransparency = 0.3
                            highlight.Parent = char
                            espHighlights[plr] = highlight
                        end
                    else
                        if espHighlights[plr] then
                            espHighlights[plr]:Destroy()
                            espHighlights[plr] = nil
                        end
                    end
                end
            end
            -- существа (модели с Humanoid, кроме игроков)
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= LocalPlayer.Character and not Players:GetPlayerFromCharacter(obj) then
                    if not espHighlights[obj] then
                        local highlight = Instance.new("Highlight")
                        highlight.Adornee = obj
                        highlight.FillColor = Color3.fromRGB(0, 255, 0)
                        highlight.FillTransparency = 0.5
                        highlight.OutlineColor = Color3.fromRGB(0, 255, 0)
                        highlight.OutlineTransparency = 0.3
                        highlight.Parent = obj
                        espHighlights[obj] = highlight
                    end
                end
            end
        end
        updateESP()
        if not espConnection then
            espConnection = RunService.Heartbeat:Connect(updateESP)
        end
    else
        if espConnection then
            espConnection:Disconnect()
            espConnection = nil
        end
        for _, h in pairs(espHighlights) do h:Destroy() end
        espHighlights = {}
    end
end


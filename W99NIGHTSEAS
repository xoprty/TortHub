local cols = 2
local btnWidth = 122
local btnHeight = 28
local gapX = 6
local gapY = 6
local startX = 6
local startY = 6

for i, data in ipairs(buttonData) do
    local text = data[1]
    local func = data[2]
    local color = data[3]
    local isToggle = data[4]
    local row = math.floor((i-1) / cols)
    local col = (i-1) % cols

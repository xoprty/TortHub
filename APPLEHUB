local TabCombat = Window:NewTab("Бой")
local SectionCombat = TabCombat:NewSection("Функции сражения")

-- Функция поиска ближайшего чела
local function getClosestPlayer(maxDistance)
    local closest = nil
    local shortestDistance = maxDistance or math.huge
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local distance = (HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if distance < shortestDistance then
                closest = p
                shortestDistance = distance
            end
        end
    end
    return closest
end

-- AUTO HIT
SectionCombat:NewToggle("AUTO HIT (Авто-удар)", "Бьет всех, кто подошел близко", function(state)
    AutoHitEnabled = state
end)

-- COMBO HIT
SectionCombat:NewToggle("COMBO HIT (Радиус 5 блоков)", "Сильно отбрасывает врагов", function(state)
    ComboHitEnabled = state
end)

-- Оптимизированный боевой поток
task.spawn(function()
    while task.wait(0.1) do
        if AutoHitEnabled then
            local target = getClosestPlayer(12)
            if target then
                local tool = Character:FindFirstChildOfClass("Tool") or Player.Backpack:FindFirstChildOfClass("Tool")
                if tool then
                    Humanoid:EquipTool(tool)
                    tool:Activate()
                end
            end
        end
        
        if ComboHitEnabled then
            local target = getClosestPlayer(5)
            if target and target.Character:FindFirstChild("HumanoidRootPart") then
                local targetHRP = target.Character.HumanoidRootPart
                local direction = (targetHRP.Position - HumanoidRootPart.Position).Unit
                targetHRP.Velocity = direction * 140
            end
        end
    end
end)


local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

-- UI Setup
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 250, 0, 450)
MainFrame.Position = UDim2.new(0.5, -125, 0.5, -225)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Active = true
MainFrame.Draggable = true

-- Заголовок и выход
local Title = Instance.new("TextLabel", MainFrame)
Title.Size = UDim2.new(1, 0, 0, 30)
Title.Text = "99 Nights Hub"
Title.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
Title.TextColor3 = Color3.new(1, 1, 1)

local CloseBtn = Instance.new("TextButton", Title)
CloseBtn.Size = UDim2.new(0, 30, 0, 30)
CloseBtn.Text = "X"
CloseBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

local Scroll = Instance.new("ScrollingFrame", MainFrame)
Scroll.Size = UDim2.new(1, 0, 1, -30)
Scroll.Position = UDim2.new(0, 0, 0, 30)
Scroll.CanvasSize = UDim2.new(0, 0, 5, 0)

local function createBtn(text, func)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(0, 230, 0, 30)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.MouseButton1Click:Connect(func)
    local layout = Instance.new("UIListLayout", Scroll)
    layout.Padding = UDim.new(0, 5)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
end

-- ЛОГИКА ЧИТОВ
local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

createBtn("INFJUMP", function()
    UserInputService.JumpRequest:Connect(function() character.Humanoid:ChangeState("Jumping") end)
end)

createBtn("JUMPBOOST", function() character.Humanoid.JumpPower = 100 end)

createBtn("FLY", function()
    local BV = Instance.new("BodyVelocity", character.HumanoidRootPart)
    BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    BV.Velocity = Vector3.new(0, 0, 0)
    -- Управление полетом можно добавить через UserInputService
end)

createBtn("TPFIRE", function() character.HumanoidRootPart.CFrame = workspace.Fire.CFrame end)

-- Функции телепортации предметов (изменяйте имена на правильные, если не работает)
local function tpItems(name)
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and v.Name == name then v.CFrame = character.HumanoidRootPart.CFrame end
    end
end

createBtn("TPBOARD", function() tpItems("Board") end)
createBtn("TPFOOD", function() tpItems("Food") end)
createBtn("TPFUEL", function() tpItems("Fuel") end)
createBtn("TPBONDAGE", function() tpItems("Bandage") end)
createBtn("TPGUN", function() tpItems("Gun") end)

createBtn("GODMODE", function() character.Humanoid.MaxHealth = 999999; character.Humanoid.Health = 999999 end)
createBtn("AUTOHEAL", function() character.Humanoid.Health = character.Humanoid.MaxHealth end)
createBtn("NOHUNGER", function() LocalPlayer.Hunger.Value = 0 end)

createBtn("SPEED (15-500)", function()
    local speed = 50 -- Можно сделать ввод через TextBox
    character.Humanoid.WalkSpeed = speed
end)

createBtn("ESP PLAYERS", function()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character and p ~= LocalPlayer then
            local highlight = Instance.new("Highlight", p.Character)
            highlight.FillColor = Color3.new(0, 1, 0)
        end
    end
end)

createBtn("TPPLAYERSME", function()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character then p.Character.HumanoidRootPart.CFrame = character.HumanoidRootPart.CFrame end
    end
end)

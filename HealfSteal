local espItemsEnabled = false
local itemHighlights = {}

local function isItem(obj)
    -- Фильтр для предметов: части, не принадлежащие игрокам, и с определёнными признаками
    if obj:IsA("BasePart") and not obj:IsA("Terrain") then
        local parent = obj.Parent
        if parent and parent:IsA("Model") and not parent:IsA("Character") then
            return true
        end
        -- Можно добавить проверку на имя, содержащее "brainrot" или "item"
        if obj.Name and (string.lower(obj.Name):find("brainrot") or string.lower(obj.Name):find("item")) then
            return true
        end
    end
    return false
end

local function scanItems()
    if not espItemsEnabled then
        for _, hl in pairs(itemHighlights) do
            hl:Destroy()
        end
        itemHighlights = {}
        return
    end
    -- Удаляем старые, если объект удалён
    for obj, hl in pairs(itemHighlights) do
        if not obj.Parent then
            hl:Destroy()
            itemHighlights[obj] = nil
        end
    end
    -- Сканируем Workspace
    for _, obj in ipairs(workspace:GetDescendants()) do
        if isItem(obj) and not itemHighlights[obj] then
            local hl = createHighlight(obj)
            itemHighlights[obj] = hl
        end
    end
end

espItemsBtn.MouseButton1Click:Connect(function()
    espItemsEnabled = not espItemsEnabled
    espItemsBtn.Text = espItemsEnabled and "ESP ITEMS (ON)" or "ESP ITEMS (OFF)"
    scanItems()
end)

-- Периодическое обновление ESP предметов (каждые 2 секунды)
task.spawn(function()
    while true do
        task.wait(2)
        if espItemsEnabled then
            scanItems()
        end
    end
end)


local espPlayerEnabled = false
local playerHighlights = {}

local function createHighlight(part)
    local hl = Instance.new("Highlight")
    hl.FillColor = Color3.fromRGB(150, 150, 150)
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0.2
    hl.Parent = part
    return hl
end

local function updatePlayerESP()
    if not espPlayerEnabled then
        for _, hl in pairs(playerHighlights) do
            hl:Destroy()
        end
        playerHighlights = {}
        return
    end
    -- Добавить всем игрокам (кроме себя)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local char = plr.Character
            if char and not playerHighlights[plr] then
                local hl = createHighlight(char)
                playerHighlights[plr] = hl
            end
        end
    end
end

espPlayerBtn.MouseButton1Click:Connect(function()
    espPlayerEnabled = not espPlayerEnabled
    espPlayerBtn.Text = espPlayerEnabled and "ESP PLAYER (ON)" or "ESP PLAYER (OFF)"
    updatePlayerESP()
end)

-- Обновление при добавлении/удалении игроков
Players.PlayerAdded:Connect(function(plr)
    if espPlayerEnabled then
        plr.CharacterAdded:Connect(function(char)
            if espPlayerEnabled then
                local hl = createHighlight(char)
                playerHighlights[plr] = hl
            end
        end)
    end
end)

Players.PlayerRemoving:Connect(function(plr)
    if playerHighlights[plr] then
        playerHighlights[plr]:Destroy()
        playerHighlights[plr] = nil
    end
end)


potatoBtn.BorderSizePixel = 0
potatoBtn.Parent = fpsbFrame

local potatoEnabled = false
local originalTechnology = Lighting.Technology
local originalBloom = Lighting.Bloom
local originalColorCorrection = Lighting.ColorCorrection

local function togglePotato(state)
    if state then
        Lighting.Technology = Enum.Technology.Compatibility
        if Lighting:FindFirstChild("Bloom") then Lighting.Bloom.Enabled = false end
        if Lighting:FindFirstChild("ColorCorrection") then Lighting.ColorCorrection.Enabled = false end
        if Lighting:FindFirstChild("SunRays") then Lighting.SunRays.Enabled = false end
        -- Дополнительно: снижаем качество текстур? Недоступно через API, но можно отключить Atmosphere и т.п.
        for _, child in ipairs(Lighting:GetChildren()) do
            if child:IsA("Atmosphere") or child:IsA("Sky") then
                child.Enabled = false
            end
        end
    else
        Lighting.Technology = originalTechnology
        if Lighting:FindFirstChild("Bloom") then Lighting.Bloom.Enabled = true end
        if Lighting:FindFirstChild("ColorCorrection") then Lighting.ColorCorrection.Enabled = true end
        if Lighting:FindFirstChild("SunRays") then Lighting.SunRays.Enabled = true end
        for _, child in ipairs(Lighting:GetChildren()) do
            if child:IsA("Atmosphere") or child:IsA("Sky") then
                child.Enabled = true
            end
        end
    end
end

potatoBtn.MouseButton1Click:Connect(function()
    potatoEnabled = not potatoEnabled
    potatoBtn.Text = potatoEnabled and "POTATOES MODE (ON)" or "POTATOES MODE (OFF)"
    togglePotato(potatoEnabled)
end)


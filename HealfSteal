fpsBoostBtn.Parent = fpsbFrame

local fpsBoostEnabled = false
local originalShadows = Lighting.Shadows
local particleEmitters = {}

local function toggleFPSBoost(state)
    if state then
        Lighting.Shadows = false
        -- Отключаем все ParticleEmitter и Beam
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Beam") then
                table.insert(particleEmitters, obj)
                obj.Enabled = false
            end
        end
    else
        Lighting.Shadows = originalShadows
        for _, obj in ipairs(particleEmitters) do
            if obj and obj.Parent then
                obj.Enabled = true
            end
        end
        particleEmitters = {}
    end
end

fpsBoostBtn.MouseButton1Click:Connect(function()
    fpsBoostEnabled = not fpsBoostEnabled
    fpsBoostBtn.Text = fpsBoostEnabled and "FPS BOOST (ON)" or "FPS BOOST (OFF)"
    toggleFPSBoost(fpsBoostEnabled)
end)

